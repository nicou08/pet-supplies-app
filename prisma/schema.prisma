// This is Prisma schema file,

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id
  name          String
  image         String?
  email         String        @unique
  emailVerified Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orders        Order[]       @relation("UserToOrder")
  reviews       Review[]      @relation("UserToReview")
  favourites    Favourite[]   @relation("UserToFavourite")
  appointments  Appointment[] @relation("UserToAppointment")
  accounts      Account[]
  sessions      Session[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model ProductType {
  id          String    @id @default(uuid())
  name        String
  displayName String?
  products    Product[] @relation("ProductToProductType")
  icon        String? // Icon name or path for the product type
  description String?
}

model PetType {
  id           String           @id @default(uuid())
  name         String
  displayName  String?
  petImageUrl  String?
  popularity   Int              @default(0)
  products     Product[]        @relation("ProductToPetType")
  // One-to-many (main pet type)
  // Many-to-many (additional pet types)
  productsMany ProductPetType[] @relation("PetTypeToProducts")
  appointments Appointment[]    @relation("PetTypeToAppointment")
}

model Brand {
  id       String    @id @default(uuid())
  name     String
  products Product[] @relation("ProductToBrand")
}

model Product {
  id                 String           @id @default(uuid())
  name               String
  description        String
  price              Float
  inStock            Boolean
  mainImageUrl       String           @db.Text
  secondaryImageUrls String[]         @db.Text
  offersType         String?
  isFeatured         Boolean          @default(false)
  isOnSale           Boolean          @default(false)
  isClearance        Boolean          @default(false)
  isNewArrival       Boolean          @default(false)
  productTypeId      String
  productType        ProductType      @relation("ProductToProductType", fields: [productTypeId], references: [id])
  petTypeId          String?
  petType            PetType?         @relation("ProductToPetType", fields: [petTypeId], references: [id])
  // One-to-many (main pet type)
  // Many-to-many (additional pet types)
  petTypes           ProductPetType[] @relation("ProductToPetTypes")
  brandId            String
  brand              Brand            @relation("ProductToBrand", fields: [brandId], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  orderItems         OrderItem[]      @relation("ProductToOrderItem")
  reviews            Review[]         @relation("ProductToReview")
  favourites         Favourite[]      @relation("ProductToFavourite")
  sales              ProductSale[]    @relation("ProductToSale")
  averageRating      Float            @default(0.0)
  numberOfRatings    Int              @default(0)

  @@index([productTypeId])
  @@index([petTypeId])
  @@index([brandId])
}

// Discount type a Sale applies. Extend this when adding new promotion kinds.
enum SaleType {
  PERCENTAGE // e.g. 20% off
  BUY_X_GET_Y // e.g. buy 3 get the 4th free
}

// A promotion that can be linked to one or more products via ProductSale.
// Sales are inserted manually (see prisma/seed.ts). Pricing logic lives in lib/pricing.ts.
model Sale {
  id           String        @id @default(uuid())
  name         String
  type         SaleType
  // PERCENTAGE only: whole-number percent off, 1–100.
  percentOff   Int?
  // BUY_X_GET_Y only: quantity the customer pays for + quantity they get free per group.
  buyQuantity  Int?
  freeQuantity Int?
  active       Boolean       @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  products     ProductSale[] @relation("SaleToProduct")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// Junction table linking a Sale to the Products it applies to.
model ProductSale {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation("ProductToSale", fields: [productId], references: [id], onDelete: Cascade)
  saleId    String
  sale      Sale    @relation("SaleToProduct", fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([productId, saleId])
  @@index([productId])
  @@index([saleId])
}

// Junction table for many-to-many relationship between Product and PetType
model ProductPetType {
  id        String  @id @default(uuid())
  productId String
  petTypeId String
  product   Product @relation("ProductToPetTypes", fields: [productId], references: [id], onDelete: Cascade)
  petType   PetType @relation("PetTypeToProducts", fields: [petTypeId], references: [id], onDelete: Cascade)

  // Ensure a product can't be linked to the same pet type twice
  @@unique([productId, petTypeId])
  @@index([productId])
  @@index([petTypeId])
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation("UserToOrder", fields: [userId], references: [id])
  totalPrice      Float
  shippingAddress String
  status          String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[] @relation("OrderToOrderItem")

  @@index([userId])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation("OrderToOrderItem", fields: [orderId], references: [id])
  productId String
  product   Product  @relation("ProductToOrderItem", fields: [productId], references: [id])
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  review    String
  userId    String
  user      User     @relation("UserToReview", fields: [userId], references: [id])
  productId String
  product   Product  @relation("ProductToReview", fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productId])
}

model Favourite {
  id        String  @id @default(uuid())
  user      User    @relation("UserToFavourite", fields: [userId], references: [id])
  userId    String
  product   Product @relation("ProductToFavourite", fields: [productId], references: [id])
  productId String

  @@unique([userId, productId])
}

model Appointment {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation("UserToAppointment", fields: [userId], references: [id])
  petTypeId             String
  petType               PetType  @relation("PetTypeToAppointment", fields: [petTypeId], references: [id])
  petName               String
  petAge                Int
  appointmentDate       DateTime
  // Canonical "HH:mm" 24-hour string aligned to a 30-minute slot. All appointments are 30 minutes long.
  appointmentTime       String
  appointmentType       String
  appointmentStatus     String
  appointmentNotes      String?
  appointmentProviderId String
  appointmentProvider   Staff    @relation("StaffToAppointment", fields: [appointmentProviderId], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([appointmentProviderId, appointmentDate, appointmentTime])
  @@index([userId])
  @@index([petTypeId])
  @@index([appointmentProviderId])
}

model Staff {
  id           String          @id @default(uuid())
  name         String
  role         String[]
  appointments Appointment[]   @relation("StaffToAppointment")
  schedules    StaffSchedule[] @relation("StaffToSchedule")
  timeOff      StaffTimeOff[]  @relation("StaffToTimeOff")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// Recurring weekly working hours for a staff member.
// One row per weekday — split shifts are intentionally not supported.
model StaffSchedule {
  id          String   @id @default(uuid())
  staffId     String
  staff       Staff    @relation("StaffToSchedule", fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      // 0 = Sunday ... 6 = Saturday
  startMinute Int      // minutes from midnight, e.g. 540 = 09:00
  endMinute   Int      // exclusive, e.g. 1020 = 17:00
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([staffId, dayOfWeek])
  @@index([staffId])
}

// Date-range exceptions where a staff member is unavailable.
model StaffTimeOff {
  id        String   @id @default(uuid())
  staffId   String
  staff     Staff    @relation("StaffToTimeOff", fields: [staffId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([staffId, startsAt, endsAt])
}
